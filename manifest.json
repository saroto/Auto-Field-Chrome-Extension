{
  "name": "Auto Fill Form",
  "description": "Automatically fills out forms on websites.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "/src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.bundled.js"],
      "css": ["src/content/ui/content.css"],
      "all_frames": true
    }
  ],
  "permissions": ["activeTab", "storage", "tabs", "windows"],
  "host_permissions": ["<all_urls>"]
}
